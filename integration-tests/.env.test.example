# ─── Integration Test Environment ───
# Copy this file to .env.test and configure as needed.
# This file is used exclusively by the integration test pipeline.

NODE_ENV=test

# Docker MySQL Container Connection
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=33066
TEST_DB_USER=root
TEST_DB_PASSWORD=root
TEST_DB_NAME=test_db_template

# Test Execution
TEST_WORKERS=4

